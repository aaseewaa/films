# FMW — backend. Скопируйте в .env и подставьте свои значения:
#   cp .env.example .env

# ─── Обязательно ─────────────────────────────────────────────────────────────

# PostgreSQL (драйвер asyncpg для FastAPI)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/films

# JWT. В продакшене — длинная случайная строка (не оставляйте dev-значение)
SECRET_KEY=dev-only-secret-change-in-production

# ─── Приложение ──────────────────────────────────────────────────────────────

APP_NAME=FMW API
APP_VERSION=0.1.0
APP_DEBUG=true

# ─── База данных (пул) ───────────────────────────────────────────────────────

DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─── Языки API ─────────────────────────────────────────────────────────────────

DEFAULT_LANGUAGE=ru
SUPPORTED_LANGUAGES=ru,en

# ─── CORS (origin фронта Vite, через запятую если несколько) ─────────────────

CORS_ORIGINS=http://localhost:5173

# ─── JWT ───────────────────────────────────────────────────────────────────────

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── Загрузки (аватары пользователей) ─────────────────────────────────────────

UPLOADS_DIR=uploads
AVATAR_MAX_BYTES=2097152

# ─── Внешние API (опционально) ───────────────────────────────────────────────
# TMDB нужен для блока новинок и части скриптов загрузки

TMDB_API_KEY=
OMDB_API_KEY=
